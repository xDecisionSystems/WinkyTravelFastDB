# Required PostgreSQL connection settings
DB_HOST=127.0.0.1
DB_PORT=5432
DB_NAME=winky_travel
DB_USER=winky
DB_PASSWORD=change-this-password
DB_SSLMODE=disable

# FastAPI runtime
API_HOST=0.0.0.0
API_PORT=8000

# Google Places proxy (recommended)
GOOGLE_MAPS_API_KEY=
GOOGLE_PLACES_BASE_URL=https://places.googleapis.com/v1
GOOGLE_TIMEOUT_SECONDS=8

# Request abuse protection
RATE_LIMIT_PER_SECOND=5
RATE_LIMIT_PER_HOUR=1000
RATE_LIMIT_PER_DAY=10000
RATE_LIMIT_RETENTION_HOURS=48

# Dev-only coding agent log access
DEV_MASTER_API_KEY=
DEV_LOG_ROOT_DIR=/var/log
DEV_LOG_MAX_BYTES=131072
DEV_LOG_MAX_LINES=400

# Optional metadata
ENVIRONMENT=production
SERVICE_NAME=winky-travel-fastdb
PROXMOX_HOST=
